# Copy this file to `.env.local` for local dev (vercel dev) and set the same vars in
# the Vercel dashboard for production. NEVER commit .env.local with real values.

# Google Sheet — the published-to-web CSV link for the leads tab.
# How to get this: open the sheet → File → Share → Publish to web → select the leads tab → CSV → Publish.
SHEET_CSV_URL=

# (Optional) Spend tab CSV link if spend lives on a separate tab.
# If spend is in the same tab as leads, leave this empty and the parser will read it from SHEET_CSV_URL.
SHEET_SPEND_CSV_URL=

# Meta Marketing API
# Long-lived system user access token with ads_read + leads_retrieval permissions.
META_ACCESS_TOKEN=

# Ad account ID, format: act_XXXXXXXXXXXXXXXX
META_AD_ACCOUNT_ID=

# Graph API version (override only if needed).
META_API_VERSION=v21.0
