# Copy this file to `.env.local` for local dev and set the same vars in
# the Vercel Project Settings → Environment Variables for production.
# NEVER commit .env.local with real values.

# ── Clerk Authentication ────────────────────────────────────────
# Create a free app at https://clerk.com → copy keys from the dashboard.

# Publishable key (safe to expose to frontend — injected into HTML by api/index.js)
CLERK_PUBLISHABLE_KEY=pk_live_

# Secret key (server-side only — NEVER expose this to the frontend)
CLERK_SECRET_KEY=sk_live_

# ── Google Sheets (CRM) ─────────────────────────────────────────
# Service account credentials JSON (from Google Cloud Console)
GOOGLE_SERVICE_ACCOUNT_JSON=

# The spreadsheet ID (from the sheet URL: /spreadsheets/d/<ID>/edit)
GOOGLE_SHEET_ID=

# Tab name inside the spreadsheet (default: Sheet1)
SHEET_TAB_NAME=Sheet1

# (Optional) Separate spend tab name
SHEET_SPEND_TAB_NAME=

# ── Meta Marketing API ──────────────────────────────────────────
# Long-lived system user access token with ads_read + leads_retrieval permissions.
META_ACCESS_TOKEN=

# Ad account ID — format: act_XXXXXXXXXXXXXXXX
META_AD_ACCOUNT_ID=

# Graph API version (only change if Meta deprecates v21.0)
META_API_VERSION=v21.0

# ── Role Setup (do in Clerk dashboard, not here) ────────────────
# After creating users in Clerk, set their role via:
#   Clerk Dashboard → Users → select user → Metadata → Public metadata:
#   { "role": "admin" }   ← Blues Agency team (full access)
#   { "role": "client" }  ← MQR team (view dashboard, no raw diagnostics)
#   { "role": "viewer" }  ← Read-only (KPIs + funnel only, no spend)
