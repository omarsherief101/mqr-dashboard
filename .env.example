# Copy this file to `.env.local` for local dev and set the same vars in
# the Vercel Project Settings → Environment Variables for production.
# NEVER commit .env.local with real values.

# ── Auth (JWT — no external service required) ───────────────────
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex

# Users JSON array — add one object per user
# Roles: admin | client | viewer
# Example:
# [{"email":"omar@blues.agency","password":"strongpass","role":"admin","name":"Omar"},{"email":"client@mqr.co","password":"viewpass","role":"client","name":"MQR Team"}]
USERS_JSON=[{"email":"admin@example.com","password":"changeme","role":"admin","name":"Admin"}]

# ── Google Sheets (CRM) ─────────────────────────────────────────
# Service account credentials JSON (from Google Cloud Console)
GOOGLE_SERVICE_ACCOUNT_JSON=

# The spreadsheet ID (from the sheet URL: /spreadsheets/d/<ID>/edit)
GOOGLE_SHEET_ID=

# Tab name inside the spreadsheet (default: Sheet1)
SHEET_TAB_NAME=Sheet1

# CSV export URL of your Google Sheet (File → Share → Publish to web → CSV)
SHEET_CSV_URL=

# ── Meta Marketing API ──────────────────────────────────────────
# Long-lived system user access token with ads_read + leads_retrieval permissions.
META_ACCESS_TOKEN=

# Ad account ID — format: act_XXXXXXXXXXXXXXXX
META_AD_ACCOUNT_ID=

# Graph API version (only change if Meta deprecates v21.0)
META_API_VERSION=v21.0
